# ─────────────────────────────────────────────
# AMJ Produce — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Payload encryption secret (generate with: openssl rand -hex 32)
PAYLOAD_SECRET=replace-with-a-long-random-string

# Postgres database connection string
# Local dev: postgresql://user:password@localhost:5432/amjproduce
# Vercel:    use your Neon connection string
DATABASE_URL=postgresql://user:password@localhost:5432/amjproduce

# Public URL of this deployment (no trailing slash)
# Local dev: http://localhost:3000
# Vercel:    https://your-project.vercel.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Initial admin user (used by: npm run seed) ──
# Set these before running `npm run seed` to create the first admin account
ADMIN_EMAIL=admin@amjproduce.com.au
ADMIN_PASSWORD=change-this-before-running-seed

# ── Optional: GitHub token for CI/CD or API integrations ──
# NOT used for CMS login — admin login is email + password only
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
